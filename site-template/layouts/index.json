{{- $pages := where .Site.RegularPages "Kind" "page" -}}
[
  {{- range $i, $page := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "description": {{ $page.Description | default $page.Summary | plainify | jsonify }},
    "categories": {{ $page.Params.categories | default slice | jsonify }},
    "tags": {{ $page.Params.tags | default slice | jsonify }},
    "content": {{ $page.Plain | truncate 500 | jsonify }}
  }
  {{- end }}
]
